# Google Gemini API Key
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_api_key_here

# Google Analytics 4 Measurement ID (public-safe, starts with G-)
# Set this for GitHub Pages deploys to enable analytics. Leave unset locally to no-op.
# Get yours from https://analytics.google.com/ > Admin > Data Streams > Web
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
